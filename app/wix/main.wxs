<?xml version='1.0' encoding='windows-1252'?>

<?if $(sys.BUILDARCH) = x64 or $(sys.BUILDARCH) = arm64 ?>
    <?define PlatformProgramFilesFolder = "ProgramFiles64Folder" ?>
<?else ?>
    <?define PlatformProgramFilesFolder = "ProgramFilesFolder" ?>
<?endif ?>

<Wix xmlns='http://schemas.microsoft.com/wix/2006/wi'>

    <!--
      Tokens rewritten by scripts/new_app.ps1:
        Synthetrix       : display name (e.g. "My App")
        synthetrix       : lowercase folder name (e.g. "myapp")
        synthetrix        : executable name without .exe (matches Cargo `[[bin]]`)
        ophiocus
        CivitAI checkpoint/LoRA harvester: fetch, pick, manifest with NVMe hotload
        https://github.com/ophiocus/synthetrix
        FE0265EA-BB63-4968-BF77-27DD0ED1A5F7   : fresh UUID per app
        7F3D2F51-2CFD-4AC6-9090-C941161B7EA3
        1CC2356F-1F1B-44CB-BF7C-959D64EE07B9
    -->
    <Product
        Id='*'
        Name='Synthetrix'
        UpgradeCode='FE0265EA-BB63-4968-BF77-27DD0ED1A5F7'
        Manufacturer='ophiocus'
        Language='1033'
        Codepage='1252'
        Version='$(var.Version)'>

        <Package Id='*'
            Keywords='Installer'
            Description='CivitAI checkpoint/LoRA harvester: fetch, pick, manifest with NVMe hotload'
            Manufacturer='ophiocus'
            InstallerVersion='450'
            Languages='1033'
            Compressed='yes'
            InstallScope='perMachine'
            SummaryCodepage='1252'
            />

        <MajorUpgrade
            Schedule='afterInstallInitialize'
            AllowSameVersionUpgrades='yes'
            DowngradeErrorMessage='A newer version of [ProductName] is already installed. Setup will now exit.'/>

        <Media Id='1' Cabinet='media1.cab' EmbedCab='yes' DiskPrompt='CD-ROM #1'/>
        <Property Id='DiskPrompt' Value='synthetrix Installation'/>

        <Directory Id='TARGETDIR' Name='SourceDir'>
            <Directory Id='$(var.PlatformProgramFilesFolder)' Name='PFiles'>
                <Directory Id='APPLICATIONFOLDER' Name='synthetrix'>

                    <Directory Id='Bin' Name='bin'>
                        <Component Id='Path' Guid='7F3D2F51-2CFD-4AC6-9090-C941161B7EA3' KeyPath='yes'>
                            <Environment
                                Id='PATH'
                                Name='PATH'
                                Value='[Bin]'
                                Permanent='no'
                                Part='last'
                                Action='set'
                                System='yes'/>
                        </Component>
                        <Component Id='binary0' Guid='*'>
                            <File
                                Id='exe0'
                                Name='synthetrix.exe'
                                DiskId='1'
                                Source='$(var.CargoTargetBinDir)\synthetrix.exe'
                                KeyPath='yes'/>
                        </Component>
                    </Directory>

                    <Component Id='DesktopShortcut' Guid='1CC2356F-1F1B-44CB-BF7C-959D64EE07B9'>
                        <Shortcut Id='DesktopShortcut'
                            Name='Synthetrix'
                            Description='CivitAI checkpoint/LoRA harvester: fetch, pick, manifest with NVMe hotload'
                            Directory='DesktopFolder'
                            Target='[Bin]synthetrix.exe'
                            WorkingDirectory='Bin'
                            Icon='ProductICO' />
                        <RegistryValue Root='HKCU'
                            Key='Software\ophiocus\Synthetrix'
                            Name='DesktopShortcut'
                            Type='integer'
                            Value='1'
                            KeyPath='yes' />
                    </Component>
                </Directory>
            </Directory>
            <Directory Id='DesktopFolder' Name='Desktop' />
        </Directory>

        <Feature
            Id='Binaries'
            Title='Application'
            Description='Installs the application binary.'
            Level='1'
            ConfigurableDirectory='APPLICATIONFOLDER'
            AllowAdvertise='no'
            Display='expand'
            Absent='disallow'>
            <ComponentRef Id='binary0'/>
            <ComponentRef Id='DesktopShortcut'/>

            <Feature
                Id='Environment'
                Title='PATH Environment Variable'
                Description='Add the install location to the PATH system environment variable.'
                Level='1'
                Absent='allow'>
                <ComponentRef Id='Path'/>
            </Feature>
        </Feature>

        <SetProperty Id='ARPINSTALLLOCATION' Value='[APPLICATIONFOLDER]' After='CostFinalize'/>

        <Icon Id='ProductICO' SourceFile='assets\icon.ico'/>
        <Property Id='ARPPRODUCTICON' Value='ProductICO' />
        <Property Id='ARPHELPLINK' Value='https://github.com/ophiocus/synthetrix'/>

        <UI>
            <UIRef Id='WixUI_FeatureTree'/>
            <Publish Dialog='WelcomeDlg' Control='Next' Event='NewDialog' Value='CustomizeDlg' Order='99'>1</Publish>
            <Publish Dialog='CustomizeDlg' Control='Back' Event='NewDialog' Value='WelcomeDlg' Order='99'>1</Publish>
        </UI>

    </Product>

</Wix>
